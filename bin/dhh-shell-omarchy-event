#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
notify="$script_dir/dhh-shell-notify"
commentary="$script_dir/dhh-shell-commentary"

usage() {
  cat >&2 <<'EOF'
usage: dhh-shell-omarchy-event EVENT

events:
  keybindings
  screenshot
  capture-menu
  recording-start
  recording-stop
  system-menu
  theme-menu
  background-menu
  update
  update-done
  theme-set [theme-name]
  font-set [font-name]
  battery-low [percent]
  post-boot
  launcher
  activity
  lazygit
  lazydocker
  lock
  workspace-switch
  reminder-done
  reload-hyprland
  restart-waybar
  dhh-wave
  dhh-think
  dhh-review
EOF
}

say() {
  local state="$1"
  local duration="$2"
  local event="$3"
  shift 3

  "$notify" --state "$state" --duration "$duration" "$("$commentary" "$event" "$@")"
}

event="${1:-}"
case "$event" in
  keybindings)
    say review 1800 keybindings
    ;;
  screenshot)
    say wave 1600 screenshot
    ;;
  capture-menu)
    say review 1600 capture-menu
    ;;
  recording-start)
    say coding 1800 recording-start
    ;;
  recording-stop)
    say jump 1600 recording-stop
    ;;
  system-menu)
    say thinking 1700 system-menu
    ;;
  theme-menu)
    say review 1700 theme-menu
    ;;
  background-menu)
    say wave 1600 background-menu
    ;;
  update)
    say thinking 2000 update
    ;;
  update-done)
    say jump 2400 update-done
    ;;
  theme-set)
    theme="${2:-new_theme}"
    say review 2200 theme-set "$theme"
    ;;
  font-set)
    font="${2:-monospace}"
    say wave 2000 font-set "$font"
    ;;
  battery-low)
    percent="${2:-low}"
    say sad 2600 battery-low "$percent"
    ;;
  post-boot)
    say wave 2200 post-boot
    ;;
  launcher)
    say wave 1400 launcher
    ;;
  activity)
    say thinking 1700 activity
    ;;
  lazygit)
    say coding 1800 lazygit
    ;;
  lazydocker)
    say thinking 1800 lazydocker
    ;;
  lock)
    say wave 1700 lock
    ;;
  workspace-switch)
    say jump 1300 workspace-switch
    ;;
  reminder-done)
    say alert 2200 reminder-done
    ;;
  reload-hyprland)
    say coding 1700 reload-hyprland
    ;;
  restart-waybar)
    say coding 1700 restart-waybar
    ;;
  dhh-wave)
    say wave 1600 dhh-wave
    ;;
  dhh-think)
    say thinking 1800 dhh-think
    ;;
  dhh-review)
    say review 1900 dhh-review
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage
    exit 1
    ;;
esac
