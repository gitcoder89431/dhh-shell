#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
notify="$script_dir/petshell-notify"

usage() {
  cat >&2 <<'EOF'
usage: petshell-omarchy-event EVENT

events:
  keybindings
  screenshot
  capture-menu
  recording-start
  recording-stop
  system-menu
  theme-menu
  background-menu
  update
  update-done
  theme-set [theme-name]
  font-set [font-name]
  battery-low [percent]
  post-boot
  launcher
  activity
EOF
}

event="${1:-}"
case "$event" in
  keybindings)
    "$notify" --state review --duration 1800 "Every shortcut is a command waiting to happen."
    ;;
  screenshot)
    "$notify" --state wave --duration 1600 "Proof or it didn't happen."
    ;;
  capture-menu)
    "$notify" --state review --duration 1600 "Screenshots, recordings, receipts."
    ;;
  recording-start)
    "$notify" --state coding --duration 1800 "Rolling tape. Make it worth the pixels."
    ;;
  recording-stop)
    "$notify" --state jump --duration 1600 "Cut. Ship the clip."
    ;;
  system-menu)
    "$notify" --state thinking --duration 1700 "Power is a menu. Use it wisely."
    ;;
  theme-menu)
    "$notify" --state review --duration 1700 "Taste is configuration."
    ;;
  background-menu)
    "$notify" --state wave --duration 1600 "Set the mood, then ship."
    ;;
  update)
    "$notify" --state thinking --duration 2000 "Ship small, upgrade often."
    ;;
  update-done)
    "$notify" --state jump --duration 2400 "The machine has been sharpened. Reboot only if the gods demand it."
    ;;
  theme-set)
    theme="${2:-new_theme}"
    "$notify" --state review --duration 2200 "New robe: ${theme}. Same shell, sharper opinions."
    ;;
  font-set)
    font="${2:-monospace}"
    "$notify" --state wave --duration 2000 "Typography is infrastructure. ${font} enters the chat."
    ;;
  battery-low)
    percent="${2:-low}"
    "$notify" --state sad --duration 2600 "Battery at ${percent}%. Even Unix prophets need electrons."
    ;;
  post-boot)
    "$notify" --state wave --duration 2200 "Boot complete. The daemon is awake."
    ;;
  launcher)
    "$notify" --state wave --duration 1400 "Summon the tools."
    ;;
  activity)
    "$notify" --state thinking --duration 1700 "Measure first. Panic later."
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage
    exit 1
    ;;
esac
