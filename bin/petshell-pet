#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
settings="$repo_root/config/settings.json"

usage() {
  printf 'usage: petshell-pet [list|set PET|current|show|scale VALUE]\n' >&2
}

cmd="${1:-current}"
case "$cmd" in
  list)
    find "$repo_root/pets" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
    ;;
  current)
    jq -r '.activePet // "dhh-pet"' "$settings"
    ;;
  show)
    jq . "$settings"
    ;;
  set)
    pet="${2:-}"
    if [ -z "$pet" ] || [ ! -f "$repo_root/pets/$pet/pet.json" ]; then
      usage
      exit 1
    fi
    tmp="$(mktemp)"
    jq --arg pet "$pet" '.activePet = $pet' "$settings" > "$tmp"
    mv "$tmp" "$settings"
    ;;
  scale)
    scale="${2:-}"
    if ! awk "BEGIN { exit !($scale >= 0.35 && $scale <= 2.0) }" 2>/dev/null; then
      printf 'scale must be between 0.35 and 2.0\n' >&2
      exit 1
    fi
    tmp="$(mktemp)"
    jq --argjson scale "$scale" '.scale = $scale' "$settings" > "$tmp"
    mv "$tmp" "$settings"
    ;;
  *)
    usage
    exit 1
    ;;
esac
