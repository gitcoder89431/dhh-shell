#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"

frame_height=208
width=1536
hybrid="$repo_root/pets/dhh-hybrid"
active="$repo_root/pets/dhh-pet"
v1="$repo_root/pets/dhh-v1-laptop/spritesheet.png"
v2="$repo_root/pets/dhh-v2/spritesheet.png"

for row in 0 1 2 3 4 5 7; do
  y=$((row * frame_height))
  magick "$v1" -crop "${width}x${frame_height}+0+${y}" +repage "/tmp/petshell-hybrid-row-${row}.png"
done

for row in 6 8; do
  y=$((row * frame_height))
  magick "$v2" -crop "${width}x${frame_height}+0+${y}" +repage "/tmp/petshell-hybrid-row-${row}.png"
done

magick \
  /tmp/petshell-hybrid-row-0.png \
  /tmp/petshell-hybrid-row-1.png \
  /tmp/petshell-hybrid-row-2.png \
  /tmp/petshell-hybrid-row-3.png \
  /tmp/petshell-hybrid-row-4.png \
  /tmp/petshell-hybrid-row-5.png \
  /tmp/petshell-hybrid-row-6.png \
  /tmp/petshell-hybrid-row-7.png \
  /tmp/petshell-hybrid-row-8.png \
  -append "$hybrid/spritesheet.png"

magick "$hybrid/spritesheet.png" "$hybrid/spritesheet.webp"
cp "$hybrid/spritesheet.png" "$active/spritesheet.png"
cp "$hybrid/spritesheet.webp" "$active/spritesheet.webp"

for row in 0 1 2 3 4 5 7; do
  y=$((row * frame_height))
  magick "$hybrid/spritesheet.png" -crop "${width}x${frame_height}+0+${y}" +repage "/tmp/petshell-check-hybrid-${row}.png"
  magick "$v1" -crop "${width}x${frame_height}+0+${y}" +repage "/tmp/petshell-check-v1-${row}.png"
  magick compare -metric AE "/tmp/petshell-check-hybrid-${row}.png" "/tmp/petshell-check-v1-${row}.png" null: >/tmp/petshell-check.out 2>&1 || {
    cat /tmp/petshell-check.out >&2
    exit 1
  }
done

for row in 6 8; do
  y=$((row * frame_height))
  magick "$hybrid/spritesheet.png" -crop "${width}x${frame_height}+0+${y}" +repage "/tmp/petshell-check-hybrid-${row}.png"
  magick "$v2" -crop "${width}x${frame_height}+0+${y}" +repage "/tmp/petshell-check-v2-${row}.png"
  magick compare -metric AE "/tmp/petshell-check-hybrid-${row}.png" "/tmp/petshell-check-v2-${row}.png" null: >/tmp/petshell-check.out 2>&1 || {
    cat /tmp/petshell-check.out >&2
    exit 1
  }
done
