#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
autostart="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/autostart.conf"
begin="# >>> dhh-shell autostart >>>"
end="# <<< dhh-shell autostart <<<"

mkdir -p "$(dirname "$autostart")"
touch "$autostart"

tmp="$(mktemp)"
awk -v begin="$begin" -v end="$end" '
  $0 == begin { skip = 1; next }
  $0 == end { skip = 0; next }
  !skip { print }
' "$autostart" > "$tmp"

cat >> "$tmp" <<EOF

$begin
exec-once = $repo_root/bin/dhh-shell-dev
$end
EOF

mv "$tmp" "$autostart"
printf 'updated %s\n' "$autostart"
printf 'reload Hyprland with: hyprctl reload\n'

